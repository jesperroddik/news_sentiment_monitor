# Copy to .env and fill in your own credentials.

# Neon serverless PostgreSQL. Must include sslmode=require.
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# NewsAPI.org key (currently unused). All sources come from RSS. NewsAPI's free
# tier was evaluated as a fallback for the feed-less outlets (TV2, Berlingske)
# but returns almost no Danish coverage, so it is not wired into the pipeline.
NEWS_API_KEY=your-newsapi-org-key
